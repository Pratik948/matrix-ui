{
  "name": "@matrixui/tokens",
  "version": "1.0.0",
  "description": "Design tokens for the MatrixUI design system — colors, typography, spacing, motion, shadows",
  "author": "MatrixUI",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/tokens/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/tokens/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/react": "^18.0.0",
    "eslint": "^8.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "keywords": [
    "design-system",
    "tokens",
    "matrix",
    "dark-theme",
    "terminal-ui",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/matrix-ui"
  }
}
